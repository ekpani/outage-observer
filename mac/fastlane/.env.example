# Copy to mac/fastlane/.env (gitignored) and fill in. Reuse the SAME App Store
# Connect API key you use for your other apps (Users and Access → Integrations →
# App Store Connect API → a key with "App Manager" access; download the .p8 once).
ASC_KEY_ID=XXXXXXXXXX
ASC_ISSUER_ID=00000000-0000-0000-0000-000000000000
ASC_KEY_PATH=~/keys/AuthKey_XXXXXXXXXX.p8
