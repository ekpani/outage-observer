<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Direct (Developer ID + notarized) distribution: NOT sandboxed, so Sparkle
       can self-update without the sandboxed-XPC dance. Security comes from
       Hardened Runtime + notarization. A separate sandboxed entitlements file is
       needed for a future Mac App Store build (where Sparkle is not used). -->
</dict>
</plist>
